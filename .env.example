TAPO_IP=192.168.x.x
ONVIF_USER=your_onvif_user
ONVIF_PASS=your_onvif_pass
TAPO_EMAIL=your_cloud_email
TAPO_CLOUD_PASS=your_cloud_password

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS is set in docker-compose.yml

# Quota limits (GCP free tier)
VIDEO_INTEL_MONTHLY_LIMIT=1000
VISION_MONTHLY_LIMIT=1000

# Download settings
DOWNLOAD_WINDOW_SIZE=50
